<div class="nav-scrollable">
    <Menu Mode="MenuMode.Inline" Accordion="true">
        @foreach (var item in webMenuTrees)
        {
            <SubMenu Key="@item.Id.ToString()" Title="@item.Name">
                @foreach (var child in item.Items)
                {
                    <MenuItem Key="@child.Id.ToString()">
                        <NavLink class="nav-link" href="@child.Path">
                            @child.Name
                        </NavLink>
                    </MenuItem>
                }
            </SubMenu>
        }
    </Menu>
</div>

@code {
    private List<WebMenuTree> webMenuTrees { get; set; } = new List<WebMenuTree>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var user_id = 0;
        int.TryParse(user.FindFirstValue("Id"), out user_id);
        if (user_id != 0)
        {
            webMenuTrees = await MenuService.GetMenuTree(user_id);
        }
    }
}